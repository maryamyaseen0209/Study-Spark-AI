# Study SparkAI backend environment
# Copy this file to .env. The app runs locally with only MongoDB and, for AI features, Groq.

# App
NODE_ENV=development
PORT=4009 
API_URL=http://localhost:4009
CLIENT_URL=http://localhost:5173

# Database: free options
# - Local MongoDB: mongodb://127.0.0.1:27017/study_sparkai
# - MongoDB Atlas free M0 cluster: https://www.mongodb.com/atlas
MONGODB_URI=mongodb://127.0.0.1:27017/study_sparkai

# JWT secrets: generate each with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=f57a318711658b9ea3d18041d75aaf61abab42f36701bc7480ba5a426108032cc301d9f37905b7a6c1f5ff6c3113d09707722044e9a222b158dfa13d749a27be
JWT_REFRESH_SECRET=f57a318711658b9ea3d18041d75aaf61abab42f36701bc7480ba5a426108032cc301d9f37905b7a6c1f5ff6c3113d09707722044e9a222b158dfa13d749a27be
JWT_RESET_SECRET=f57a318711658b9ea3d18041d75aaf61abab42f36701bc7480ba5a426108032cc301d9f37905b7a6c1f5ff6c3113d09707722044e9a222b158dfa13d749a27be
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d
PASSWORD_RESET_TTL=1h
COOKIE_SECURE=false

# AI: Groq free API keys from https://console.groq.com
# Free model defaults: llama-3.1-8b-instant, mixtral-8x7b-32768, gemma2-9b-it
GROQ_API_KEY=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
GROQ_MODEL=llama-3.1-8b-instant
GROQ_REASONING_MODEL=mixtral-8x7b-32768
GROQ_EXPLANATION_MODEL=gemma2-9b-it

# File uploads
# Optional: Cloudinary free tier at https://cloudinary.com. Leave blank to use local upload fallback when implemented.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Redis caching/queues
# Optional: Upstash free Redis at https://upstash.com or local Redis. Leave blank to disable Redis features.
REDIS_URL=

# Zoom meetings
# Optional: create a Zoom Server-to-Server OAuth app at https://marketplace.zoom.us. Leave blank to disable Zoom features.
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
